# Server
PORT=4000
HOST=0.0.0.0
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
# Optional: allow Vercel preview deployments. Use carefully.
# Example allows https://anything.vercel.app
VERCEL_PREVIEW_ORIGIN_REGEX=^https://.*\\.vercel\\.app$

# Database (PostgreSQL – e.g. Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Auth (JWT)
JWT_SECRET=your-super-secret-key-change-in-production

# OAuth – Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth – GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google Maps – enable Geocoding API + Places API
GOOGLE_MAPS_API_KEY=

# Prayer times (optional override)
ALADHAN_API_BASE=https://api.aladhan.com/v1
